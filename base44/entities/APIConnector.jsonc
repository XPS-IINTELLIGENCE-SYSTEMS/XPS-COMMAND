{
  "name": "APIConnector",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Display name"
    },
    "service_type": {
      "type": "string",
      "enum": [
        "github",
        "supabase",
        "anthropic",
        "twilio",
        "heygen",
        "google_cloud",
        "google_drive",
        "google_sheets",
        "google_docs",
        "google_keep",
        "google_tasks",
        "hubspot",
        "airtable",
        "gmail",
        "openai",
        "base44",
        "redis",
        "neon",
        "xps_lead_sniper",
        "construct_connect",
        "dodge_reports",
        "planhub",
        "building_connected",
        "isqft",
        "bidclerk",
        "the_blue_book",
        "sam_gov",
        "usaspending",
        "fpds",
        "fbo_gov",
        "gsa_ebuy",
        "beta_sam",
        "grants_gov",
        "sbir_gov",
        "census_gov",
        "data_gov",
        "steel_dev",
        "browserless",
        "aws",
        "slack",
        "groq",
        "ollama",
        "openrouter",
        "vercel",
        "sendgrid",
        "stripe",
        "zapier",
        "apify",
        "brightdata",
        "zoominfo",
        "apolloio",
        "linkedin",
        "google_calendar",
        "elevenlabs",
        "replicate",
        "together_ai",
        "mistral",
        "perplexity",
        "serper",
        "tavily",
        "firecrawl",
        "custom"
      ],
      "description": "Service identifier"
    },
    "api_key": {
      "type": "string",
      "description": "API key or token"
    },
    "secondary_key": {
      "type": "string",
      "description": "Secondary key (e.g. Auth Token, Secret Key)"
    },
    "base_url": {
      "type": "string",
      "description": "API base URL"
    },
    "webhook_url": {
      "type": "string"
    },
    "is_enabled": {
      "type": "boolean",
      "default": false
    },
    "connection_status": {
      "type": "string",
      "enum": [
        "untested",
        "connected",
        "error",
        "expired"
      ],
      "default": "untested"
    },
    "last_tested": {
      "type": "string",
      "format": "date-time"
    },
    "last_response_ms": {
      "type": "number"
    },
    "error_log": {
      "type": "string"
    },
    "docs_url": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "monthly_calls": {
      "type": "number",
      "default": 0
    },
    "monthly_cost_estimate": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "name",
    "service_type"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}