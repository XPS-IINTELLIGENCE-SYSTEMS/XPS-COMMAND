{
  "name": "AgentJob",
  "type": "object",
  "properties": {
    "agent_type": {
      "type": "string",
      "enum": [
        "Coordinator",
        "Browser",
        "Research",
        "Scraper",
        "Writer",
        "Analyst",
        "Coder",
        "Scheduler",
        "Outreach",
        "Proposal",
        "Call",
        "Content",
        "Analysis",
        "SEO",
        "Social",
        "Shadow Browser",
        "Site Builder",
        "Crawler Network",
        "Property Builder"
      ],
      "description": "Type of agent running this job"
    },
    "job_description": {
      "type": "string",
      "description": "What the agent needs to do"
    },
    "goal": {
      "type": "string",
      "description": "High-level user goal this job is part of"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "planning",
        "running",
        "retrying",
        "complete",
        "failed",
        "paused",
        "cancelled"
      ],
      "default": "queued"
    },
    "priority": {
      "type": "number",
      "description": "Priority 1-10 (10=highest)"
    },
    "step_current": {
      "type": "number",
      "default": 0,
      "description": "Current execution step"
    },
    "step_total": {
      "type": "number",
      "default": 0,
      "description": "Total planned steps"
    },
    "retry_count": {
      "type": "number",
      "default": 0
    },
    "max_retries": {
      "type": "number",
      "default": 3
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "result": {
      "type": "string",
      "description": "Output or result JSON"
    },
    "error": {
      "type": "string"
    },
    "trigger_source": {
      "type": "string",
      "enum": [
        "manual",
        "schedule",
        "agent_handoff",
        "webhook",
        "system",
        "goal"
      ],
      "default": "manual"
    },
    "parent_job_id": {
      "type": "string",
      "description": "Parent job ID if this is a sub-task"
    },
    "output_handed_to": {
      "type": "string"
    },
    "execution_log": {
      "type": "string",
      "description": "JSON array of step-by-step log entries"
    },
    "memory_context": {
      "type": "string"
    },
    "tool_calls": {
      "type": "string",
      "description": "JSON array of tools called by this job"
    },
    "live_output": {
      "type": "string",
      "description": "Current streaming output for live display"
    }
  },
  "required": [
    "agent_type",
    "job_description",
    "status"
  ]
}