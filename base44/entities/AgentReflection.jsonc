{
  "name": "AgentReflection",
  "type": "object",
  "properties": {
    "agent_type": {
      "type": "string",
      "description": "Agent that performed the reflection"
    },
    "reflection_type": {
      "type": "string",
      "enum": [
        "performance_review",
        "skill_gap",
        "self_correction",
        "collaboration_review",
        "strategy_upgrade"
      ],
      "default": "performance_review"
    },
    "trigger": {
      "type": "string",
      "enum": [
        "post_task",
        "scheduled",
        "failure_recovery",
        "collaboration_end",
        "manual"
      ],
      "default": "post_task"
    },
    "summary": {
      "type": "string",
      "description": "Human-readable summary of the reflection"
    },
    "performance_score": {
      "type": "number",
      "description": "Self-assessed score 0-100"
    },
    "tasks_analyzed": {
      "type": "number",
      "default": 0
    },
    "success_rate": {
      "type": "number",
      "description": "Percentage 0-100"
    },
    "strengths": {
      "type": "string",
      "description": "JSON array of identified strengths"
    },
    "weaknesses": {
      "type": "string",
      "description": "JSON array of identified weaknesses"
    },
    "improvements_applied": {
      "type": "string",
      "description": "JSON array of improvements the agent applied to itself"
    },
    "skill_upgrades": {
      "type": "string",
      "description": "JSON array of new skills/tools the agent recommended adding"
    },
    "prompt_optimizations": {
      "type": "string",
      "description": "JSON array of prompt/strategy adjustments made"
    },
    "collaboration_insights": {
      "type": "string",
      "description": "JSON \u2014 insights on multi-agent coordination"
    },
    "collaboration_score": {
      "type": "number",
      "description": "Multi-agent collaboration quality score 0-100"
    },
    "before_metrics": {
      "type": "string",
      "description": "JSON \u2014 metrics before reflection cycle"
    },
    "after_metrics": {
      "type": "string",
      "description": "JSON \u2014 metrics after applying improvements"
    },
    "full_analysis": {
      "type": "string",
      "description": "Full LLM-generated analysis text"
    },
    "next_actions": {
      "type": "string",
      "description": "JSON array of recommended next actions"
    },
    "related_job_ids": {
      "type": "string",
      "description": "JSON array of AgentJob IDs analyzed"
    },
    "status": {
      "type": "string",
      "enum": [
        "analyzing",
        "complete",
        "applied",
        "failed"
      ],
      "default": "analyzing"
    }
  },
  "required": [
    "agent_type",
    "reflection_type",
    "status"
  ]
}