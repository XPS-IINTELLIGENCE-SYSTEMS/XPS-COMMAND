{
  "name": "CustomAgent",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Agent name"
    },
    "description": {
      "type": "string",
      "description": "What this agent does"
    },
    "avatar_url": {
      "type": "string",
      "description": "AI-generated logo/avatar URL"
    },
    "brain_model": {
      "type": "string",
      "enum": [
        "gpt_5_mini",
        "gpt_5",
        "gpt_5_4",
        "gemini_3_flash",
        "gemini_3_1_pro",
        "claude_sonnet_4_6",
        "claude_opus_4_6",
        "claude_opus_4_7",
        "groq_llama",
        "ollama_local"
      ],
      "default": "gpt_5_mini",
      "description": "Primary LLM brain"
    },
    "memory_enabled": {
      "type": "boolean",
      "default": true
    },
    "knowledge_sources": {
      "type": "string",
      "description": "JSON array of knowledge source IDs or URLs"
    },
    "autonomy_level": {
      "type": "string",
      "enum": [
        "full_autonomous",
        "semi_autonomous",
        "chatbot"
      ],
      "default": "chatbot"
    },
    "capabilities": {
      "type": "string",
      "description": "JSON array of enabled capability IDs"
    },
    "tool_access": {
      "type": "string",
      "description": "JSON array of tool IDs the agent can use"
    },
    "api_keys": {
      "type": "string",
      "description": "JSON object of key-value pairs for agent-specific API keys"
    },
    "instructions": {
      "type": "string",
      "description": "System prompt / custom instructions"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "draft",
        "archived"
      ],
      "default": "draft"
    },
    "parallel_enabled": {
      "type": "boolean",
      "default": false
    },
    "async_enabled": {
      "type": "boolean",
      "default": false
    },
    "fleet_priority": {
      "type": "number",
      "default": 5,
      "description": "Priority in fleet 1-10"
    },
    "total_runs": {
      "type": "number",
      "default": 0
    },
    "last_run": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "name",
    "brain_model",
    "status"
  ]
}