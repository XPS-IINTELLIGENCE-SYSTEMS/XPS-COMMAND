{
  "name": "IntelRecord",
  "type": "object",
  "properties": {
    "source_company": {
      "type": "string",
      "enum": [
        "XPS",
        "NCP",
        "XPS Xpress",
        "CPU",
        "Epoxy Network",
        "XPS Intelligence",
        "XPS Location",
        "Industry",
        "GitHub",
        "Custom"
      ],
      "default": "Custom",
      "description": "Which XPS brand or source this intel belongs to"
    },
    "category": {
      "type": "string",
      "enum": [
        "website",
        "pricing",
        "product",
        "social_media",
        "youtube",
        "video",
        "image",
        "branding",
        "keywords",
        "seo",
        "review",
        "news",
        "job_posting",
        "financial",
        "legal",
        "patent",
        "location",
        "team",
        "training",
        "certification",
        "event",
        "case_study",
        "testimonial",
        "industry_data",
        "market_trend",
        "technology",
        "github_repo",
        "template",
        "agent_skill",
        "custom"
      ],
      "default": "custom"
    },
    "industry": {
      "type": "string",
      "description": "Industry vertical this data belongs to"
    },
    "sub_industry": {
      "type": "string",
      "description": "Sub-industry or niche"
    },
    "title": {
      "type": "string",
      "description": "Short title or headline"
    },
    "content": {
      "type": "string",
      "description": "Full scraped/ingested content text"
    },
    "summary": {
      "type": "string",
      "description": "AI-generated summary"
    },
    "source_url": {
      "type": "string"
    },
    "source_type": {
      "type": "string",
      "enum": [
        "scraper",
        "crawler",
        "llm_research",
        "manual",
        "api",
        "social",
        "github",
        "rss",
        "webhook",
        "browserless"
      ],
      "default": "manual"
    },
    "tags": {
      "type": "string",
      "description": "Comma-separated tags for indexing"
    },
    "confidence_score": {
      "type": "number",
      "description": "0-100 confidence in data accuracy"
    },
    "scraped_at": {
      "type": "string",
      "format": "date-time"
    },
    "scraper_job_id": {
      "type": "string"
    },
    "is_indexed": {
      "type": "boolean",
      "default": false
    },
    "data_freshness": {
      "type": "string",
      "enum": [
        "live",
        "recent",
        "stale",
        "archived"
      ],
      "default": "recent"
    },
    "location_name": {
      "type": "string",
      "description": "XPS franchise location name if applicable"
    },
    "location_state": {
      "type": "string",
      "description": "State abbreviation for location-specific intel"
    },
    "pricing_data": {
      "type": "string",
      "description": "JSON structured pricing information"
    },
    "keyword_data": {
      "type": "string",
      "description": "JSON array of keywords, phrases, SEO terms extracted"
    },
    "engagement_metrics": {
      "type": "string",
      "description": "JSON social engagement data \u2014 likes, shares, views, followers"
    },
    "metadata": {
      "type": "string",
      "description": "JSON blob of extra structured data"
    }
  },
  "required": [
    "title",
    "category"
  ]
}