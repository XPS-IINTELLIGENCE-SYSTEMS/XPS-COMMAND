{
  "name": "Lead",
  "type": "object",
  "properties": {
    "company": {
      "type": "string",
      "description": "Company name"
    },
    "contact_name": {
      "type": "string",
      "description": "Primary contact person"
    },
    "email": {
      "type": "string",
      "description": "Contact email"
    },
    "phone": {
      "type": "string",
      "description": "Contact phone number"
    },
    "website": {
      "type": "string",
      "description": "Company website URL"
    },
    "vertical": {
      "type": "string",
      "enum": [
        "Retail",
        "Food & Bev",
        "Warehouse",
        "Automotive",
        "Healthcare",
        "Fitness",
        "Education",
        "Industrial",
        "Residential",
        "Government",
        "Other"
      ],
      "description": "Industry vertical"
    },
    "location": {
      "type": "string",
      "description": "City, State"
    },
    "city": {
      "type": "string",
      "description": "City"
    },
    "state": {
      "type": "string",
      "description": "State"
    },
    "zip": {
      "type": "string",
      "description": "ZIP code"
    },
    "employee_count": {
      "type": "number",
      "description": "Number of employees"
    },
    "existing_material": {
      "type": "string",
      "description": "Current flooring material in use"
    },
    "equipment_used": {
      "type": "string",
      "description": "Equipment currently used at facility"
    },
    "square_footage": {
      "type": "number",
      "description": "Estimated square footage"
    },
    "estimated_value": {
      "type": "number",
      "description": "Estimated deal value"
    },
    "score": {
      "type": "number",
      "description": "AI lead score 0-100"
    },
    "priority": {
      "type": "number",
      "description": "Priority ranking 1-10 (10=highest)"
    },
    "lead_type": {
      "type": "string",
      "enum": [
        "XPress",
        "Jobs"
      ],
      "default": "XPress",
      "description": "XPress = material/equipment/training sales leads. Jobs = contract work leads."
    },
    "stage": {
      "type": "string",
      "enum": [
        "Incoming",
        "Validated",
        "Qualified",
        "Prioritized",
        "Contacted",
        "Proposal",
        "Negotiation",
        "Won",
        "Lost"
      ],
      "default": "Incoming"
    },
    "pipeline_status": {
      "type": "string",
      "enum": [
        "Incoming",
        "Validated",
        "Prioritized",
        "Qualified"
      ],
      "default": "Incoming",
      "description": "Lead pipeline validation status"
    },
    "ingestion_source": {
      "type": "string",
      "enum": [
        "ChatGPT",
        "Scraper",
        "Attachment",
        "Google Drive",
        "Supabase",
        "Manual",
        "HubSpot",
        "Other"
      ],
      "default": "Manual",
      "description": "How this lead was ingested"
    },
    "source": {
      "type": "string",
      "description": "Lead source detail"
    },
    "ai_insight": {
      "type": "string",
      "description": "AI-generated insight about this lead"
    },
    "ai_recommendation": {
      "type": "string",
      "description": "AI product recommendation based on XPS products vs their existing line"
    },
    "profile_data": {
      "type": "string",
      "description": "JSON string of deep business profile data"
    },
    "profile_url": {
      "type": "string",
      "description": "Link to full profile on Google Drive"
    },
    "validation_notes": {
      "type": "string",
      "description": "Notes from the validation agent"
    },
    "notes": {
      "type": "string",
      "description": "Notes about the lead"
    },
    "last_contacted": {
      "type": "string",
      "format": "date-time",
      "description": "Last contact date"
    },
    "years_in_business": {
      "type": "number",
      "description": "Years the company has been in business"
    }
  },
  "required": [
    "company",
    "contact_name",
    "stage"
  ]
}